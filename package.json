{
  "name": "english-learning-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "check:environment": "node scripts/check-environment.mjs",
    "dev": "npm run dev --workspace=@app/desktop",
    "desktop": "npm run tauri --workspace=@app/desktop -- dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "test:performance": "vitest run testing/performance",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:structure": "node scripts/check-structure.mjs",
    "check:migrations": "node scripts/check-native-migration-sources.mjs",
    "check:forbidden": "node scripts/check-forbidden-patterns.mjs",
    "check:css-tokens": "node scripts/check-css-custom-properties.mjs",
    "check:dead-code": "knip --reporter compact",
    "quality": "npm run check:structure && npm run check:migrations && npm run check:forbidden && npm run check:css-tokens && npm run check:dead-code && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "check:native-environment": "node scripts/check-native-environment.mjs",
    "check:git": "node scripts/check-git-hygiene.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "check:release-metadata": "node scripts/check-release-metadata.mjs",
    "check:release-artifacts": "node scripts/check-release-artifacts.mjs",
    "generate:native-schemas": "tsx scripts/generate-native-json-schemas.ts",
    "check:native-schemas": "tsx scripts/generate-native-json-schemas.ts --check",
    "quality:release": "npm run check:structure && npm run check:migrations && npm run check:forbidden && npm run check:css-tokens && npm run check:dead-code && npm run format:check && npm run lint && npm run check:native-schemas && npm run check:release-metadata && npm run check:core-content && npm run typecheck && npm run test && npm run test:performance && npm run build && npm run test:e2e && npm run check:bundle",
    "release:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-windows-installers.ps1",
    "release:windows:unsigned": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-windows-installers.ps1 -AllowUnsigned",
    "release:windows:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-installers.ps1",
    "release:windows:verify:unsigned": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-installers.ps1 -AllowUnsigned",
    "check:core-content": "node scripts/check-core-content.mjs",
    "quality:content": "npm run check:structure && npm run check:forbidden && npm run check:release-metadata && npm run check:core-content && npm run typecheck && npm run test && npm run build && npm run check:bundle"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.18.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.5.0",
    "knip": "^6.27.0",
    "prettier": "^3.7.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.0",
    "zod": "^4.4.3"
  }
}
