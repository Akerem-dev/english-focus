{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "general": {
      "type": "object",
      "properties": {
        "interfaceLanguage": { "type": "string", "const": "en" },
        "translationLanguage": { "type": "string", "const": "tr" }
      },
      "required": ["interfaceLanguage", "translationLanguage"],
      "additionalProperties": false
    },
    "content": {
      "type": "object",
      "properties": {
        "showEtymology": { "type": "boolean" },
        "showCommonMistakes": { "type": "boolean" },
        "exampleSentenceCount": {
          "anyOf": [
            { "type": "number", "const": 5 },
            { "type": "number", "const": 10 }
          ]
        }
      },
      "required": ["showEtymology", "showCommonMistakes", "exampleSentenceCount"],
      "additionalProperties": false
    },
    "data": {
      "type": "object",
      "properties": {
        "automaticBackups": { "type": "boolean" },
        "backupFrequency": { "type": "string", "enum": ["daily", "weekly", "manual"] }
      },
      "required": ["automaticBackups", "backupFrequency"],
      "additionalProperties": false
    },
    "appearance": {
      "type": "object",
      "properties": {
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "reducedMotion": { "type": "boolean" },
        "interfaceSize": { "type": "string", "enum": ["compact", "medium", "large"] }
      },
      "required": ["theme", "reducedMotion", "interfaceSize"],
      "additionalProperties": false
    },
    "instruction": {
      "type": "object",
      "properties": {
        "explanationLanguage": { "type": "string", "const": "tr" },
        "detailLevel": { "type": "string", "enum": ["balanced", "detailed", "maximum"] },
        "targetProficiency": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
        "exampleCount": { "type": "number", "const": 10 },
        "includeWordFamily": { "type": "boolean" },
        "includeGrammarNotes": { "type": "boolean" },
        "includeCommonMistakes": { "type": "boolean" },
        "includeEtymology": { "type": "boolean" },
        "includeUsageTips": { "type": "boolean" }
      },
      "required": [
        "explanationLanguage",
        "detailLevel",
        "targetProficiency",
        "exampleCount",
        "includeWordFamily",
        "includeGrammarNotes",
        "includeCommonMistakes",
        "includeEtymology",
        "includeUsageTips"
      ],
      "additionalProperties": false
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "schemaVersion",
    "general",
    "content",
    "data",
    "appearance",
    "instruction",
    "updatedAt"
  ],
  "additionalProperties": false
}
